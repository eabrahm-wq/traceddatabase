{
  "manifest_version": 3,
  "name": "Traced — Brand Intelligence",
  "version": "1.0.0",
  "description": "See who really owns what you buy. Traces brand ownership, violations, and lobbying on grocery sites.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://www.instacart.com/*",
    "https://www.amazon.com/*",
    "https://www.wholefoodsmarket.com/*",
    "https://www.safeway.com/*",
    "https://www.walmart.com/*",
    "https://www.target.com/*",
    "https://www.kroger.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instacart.com/*",
        "https://www.amazon.com/*",
        "https://www.wholefoodsmarket.com/*",
        "https://www.safeway.com/*",
        "https://www.walmart.com/*",
        "https://www.target.com/*",
        "https://www.kroger.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
